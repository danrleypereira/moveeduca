<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1comm01" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.42.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.24.0">
  <bpmn:collaboration id="Collaboration_1xz9y72">
    <bpmn:participant id="Participant_0vk8s92" name="Processo de Comunicação e Divulgação" processRef="Process_1h5x9s2" />
    <bpmn:textAnnotation id="TextAnnotation_0msx68u">
      <bpmn:text>Art. 2º, I: Promover, desenvolver, realizar e divulgar pesquisas, estudos, trabalhos, educação e o ensino em todos os campos do saber, com foco na manutenção e desenvolvimento da educação pública, privada, confessional e comunitária.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_11frnkj">
      <bpmn:text>Art. 19º: As Assembleias Gerais serão convocadas [...] através de edital publicado com antecedência mínima de 7 (sete) dias, contendo o dia, hora, local e ordem do dia, em jornal de circulação local e/ou meio eletrônico.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_02wgj33">
      <bpmn:text>Art. 35º, I: A publicação por qualquer meio eficaz, no encerramento do exercício fiscal, do relatório de atividades e das demonstrações financeiras da organização, incluindo-se as certidões negativas de débitos junto ao INSS e ao FGTS, colocando-os à disposição para o exame de qualquer cidadão;</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0v9y56o">
      <bpmn:text>Art. 24º, I: Representar a MoveEduca ativa e passivamente, judicial e extrajudicialmente; (Nota: Todo ato de comunicação oficial é um ato de representação da entidade, competência do Presidente).</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0cj29gx">
      <bpmn:text>Art. 25º Compete ao Vice-Presidente:
I.Publicar todas as notícias das atividades da entidade;</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1nme03s" associationDirection="None" sourceRef="Activity_1a2b3c4" targetRef="TextAnnotation_11frnkj" />
    <bpmn:association id="Association_0j0zlmg" associationDirection="None" sourceRef="StartEvent_1" targetRef="TextAnnotation_0msx68u" />
    <bpmn:association id="Association_1dcqol8" associationDirection="None" sourceRef="TextAnnotation_02wgj33" targetRef="Activity_0s1d2f3" />
  </bpmn:collaboration>
