<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_0qw41kw" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.42.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.0.0">
  <bpmn:collaboration id="Collaboration_0sbtb6d">
    <bpmn:participant id="Participant_0q19gva" name="Processo de Parcerias e Convênios" processRef="Process_1lqcw2i" />
    <bpmn:textAnnotation id="TextAnnotation_1rafh4q">
      <bpmn:text>Dia 25/02 Esse aqui precisa refazer inteiro? talvez</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1kym33z">
      <bpmn:text>Formulário com coisas como nome da organização, cnpj, endereço e etc...</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_00vxhh9">
      <bpmn:text>Art. 26º, inciso I: Compete ao Presidente representar a associação ativa e passivamente, judicial e extrajudicialmente.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1hbdzp7">
      <bpmn:text>Art. 2º, IV: Desenvolver, executar e administrar, diretamente ou em parceria, serviços, programas e projetos de educação, ensino, pesquisas, estudos e trabalhos;</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1imhjzy">
      <bpmn:text>Art. 28º, I: Opinar sobre o planejamento anual, planos de aplicação e projetos de atividades da associação</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1hlsh1n">
      <bpmn:text>Art. 30º, II: Examinar, a qualquer tempo, os livros e documentos da associação, bem como o estado do caixa;</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0xgikm9">
      <bpmn:text>Art. 17º: A Assembleia Geral é o órgão soberano da MoveEduca e se constituirá dos associados fundadores e efetivos em pleno gozo de seus direitos estatutários.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_17r3pj0">
      <bpmn:text>Art. 24º, I: Representar a MoveEduca ativa e passivamente, judicial e extrajudicialmente;</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1qzij5z">
      <bpmn:text>Art. 27º, V: Organizar e manter o arquivo de documentos legais e históricos da entidade;</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0zunh5s">
      <bpmn:text>Art. 25º, II: Elaborar o plano anual de atividades e o orçamento;</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0kk5vi4" associationDirection="None" sourceRef="Activity_1vrbgxh" targetRef="TextAnnotation_1kym33z" />
