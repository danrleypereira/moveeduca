<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1ellrup" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.42.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.24.0">
  <bpmn:collaboration id="Collaboration_19uuo3e">
    <bpmn:participant id="Participant_0m8cvsi" name="Auditoria e compliance" processRef="Process_0522io7" />
    <bpmn:textAnnotation id="TextAnnotation_1pb27i6">
      <bpmn:text>Art. 28º: Compete ao Conselho de Administração: I. Opinar sobre o planejamento anual, planos de aplicação e projetos de atividades da associação; IX. Zelar pelo cumprimento dos objetivos da associação.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_08ckweu">
      <bpmn:text>Art. 30º: Compete ao Conselho Fiscal: I. Dar parecer escrito sobre as demonstrações financeiras, o balanço e as contas da Diretoria; II. Examinar, a qualquer tempo, os livros e documentos da associação, bem como o estado do caixa; IV. Convocar a Assembleia Geral se ocorrerem motivos graves e urgentes; Parágrafo Único. O Conselho Fiscal poderá contratar auditoria externa, cujos custos serão suportados pela associação.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1n3nml7">
      <bpmn:text>Art. 35º: A prestação de contas da associação observará: I. A publicação por qualquer meio eficaz, no encerramento do exercício fiscal, do relatório de atividades e das demonstrações financeiras da organização; II. A realização de auditoria, inclusive por auditores externos independentes se for o caso, da aplicação dos eventuais recursos objeto de termo de parceria.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0eqaw0k">
      <bpmn:text>Art. 25º: Compete à Diretoria Executiva: II. Elaborar o plano anual de atividades e o orçamento; VIII. Prestar contas anualmente à Assembleia Geral e ao Conselho Fiscal.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_13r2luz" associationDirection="None" sourceRef="StartEvent_1" targetRef="TextAnnotation_1pb27i6" />
    <bpmn:association id="Association_100rdui" associationDirection="None" sourceRef="Activity_0ys2wkh" targetRef="TextAnnotation_08ckweu" />
    <bpmn:association id="Association_18zjo3o" associationDirection="None" sourceRef="Activity_1psh27m" targetRef="TextAnnotation_1n3nml7" />
    <bpmn:association id="Association_1udl6nr" associationDirection="None" sourceRef="Activity_1nkxmzb" targetRef="TextAnnotation_0eqaw0k" />
  </bpmn:collaboration>
