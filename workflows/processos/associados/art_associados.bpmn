<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_06ekgjm" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.42.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.24.0">
  <bpmn:collaboration id="Collaboration_1af204f">
    <bpmn:participant id="Participant_1gp64d8" name="Processo de Admissão de Associados" processRef="Process_0easgkq" />
    <bpmn:textAnnotation id="TextAnnotation_1pap92e">
      <bpmn:text>Fomulário online (Google forms) com dados simples como -&gt; Nome; Idade; CPF, Certificado de idoneidade; Nada consta; Contato; endereço e etc...</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1dybv9s">
      <bpmn:text>- Art. 27º, VI: "Receber as propostas de admissão e desligamento dos associados".</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_192zwef">
      <bpmn:text>Art. 7º : "A admissão de associados se dará por meio de solicitação do interessado à Diretoria, que decidirá por maioria absoluta".</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_01cjtxa">
      <bpmn:text>Art. 10º, IV: "aqueles designados como associados, admitidos após a fundação desta associação... submetidos à aprovação da Assembléia Geral por meio de votação com maioria simples".</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1ovytuj">
      <bpmn:text>Art. 12º, III: "Participar ativamente das atividades e eventos organizados pela MoveEduca".</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0vrwi4e" associationDirection="None" sourceRef="Activity_0m53y28" targetRef="TextAnnotation_1pap92e" />
    <bpmn:association id="Association_1542wre" associationDirection="None" sourceRef="Activity_12ajdoi" targetRef="TextAnnotation_192zwef" />
    <bpmn:association id="Association_0ek7raz" associationDirection="None" sourceRef="Activity_1upjuav" targetRef="TextAnnotation_01cjtxa" />
    <bpmn:association id="Association_0qbt35n" associationDirection="None" sourceRef="Activity_1q01k34" targetRef="TextAnnotation_1ovytuj" />
    <bpmn:association id="Association_0obahwd" associationDirection="None" sourceRef="Activity_0zhi0uu" targetRef="TextAnnotation_1dybv9s" />
  </bpmn:collaboration>
