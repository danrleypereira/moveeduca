<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1fin02" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.42.0">
  <bpmn:collaboration id="Collaboration_MacroContabil">
    <bpmn:participant id="Participant_Contabil" name="Processo de Gestão Contábil e Fiscal Anual" processRef="Process_Contabilidade_Macro" />
    <bpmn:textAnnotation id="TextAnnotation_1qu06ey">
      <bpmn:text>Art. 25º, I: Publicar todas as notícias das atividades da entidade</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_05awemx">
      <bpmn:text>Art. 17º, III: Discutir e homologar as contas e o balanço aprovado pelo Conselho fiscal</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0avy0vf">
      <bpmn:text>Art. 31º, II: Opinar sobre os balanços e relatórios de desempenho financeiro e contábil e sobre as operações patrimoniais realizadas, emitindo pareceres para os organismo superiores da entidade;</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_02n1re5">
      <bpmn:text>Art. 22º, V: Levar à apreciação da Assembleia Geral Ordinária seu relatório anual e o balanço financeiro com parecer do Conselho Fiscal e, no fim de seu mandato, apresentar um relatório geral de sua gestão;</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1hj32yb">
      <bpmn:text>Art. 31º, I: Examinar os livros de escrituração da organização; 
Art. 31º, Parágrafo Único: O Conselho Fiscal reunir-se-á, por regra, a cada 06 meses.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1bu1017">
      <bpmn:text>Art. 29º, VII: assegurar que seus recursos financeiros tenham o rendimento condizente com perfil de risco adequado, que os recursos sejam gerenciados com eficiência, monitorando a gestão patrimonial dos ativos da associação e a elaboração e execução orçamentária realizada pelos gestores;</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0ypt5hy">
      <bpmn:text>Art. 17º, I: Aprovar a proposta de programação anual da organização, submetida pela Diretoria.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_16wkbnd">
      <bpmn:text>Art. 22º, I: Elaborar e submeter à Assembléia Geral a proposta de programação anual da organização;</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1d2gttj" associationDirection="None" sourceRef="Activity_T8" targetRef="TextAnnotation_1qu06ey" />
    <bpmn:association id="Association_1yuun5d" associationDirection="None" sourceRef="Activity_T7" targetRef="TextAnnotation_05awemx" />
    <bpmn:association id="Association_18un7ss" associationDirection="None" sourceRef="Activity_T6" targetRef="TextAnnotation_0avy0vf" />
    <bpmn:association id="Association_0cepsob" associationDirection="None" sourceRef="Activity_T5" targetRef="TextAnnotation_02n1re5" />
    <bpmn:association id="Association_0b9qg6e" associationDirection="None" sourceRef="Activity_T4" targetRef="TextAnnotation_1hj32yb" />
    <bpmn:association id="Association_1ypuaxm" associationDirection="None" sourceRef="Activity_T2" targetRef="TextAnnotation_1bu1017" />
    <bpmn:association id="Association_18vljqz" associationDirection="None" sourceRef="Activity_T3" targetRef="TextAnnotation_0ypt5hy" />
    <bpmn:association id="Association_01yb1lb" associationDirection="None" sourceRef="Activity_T1" targetRef="TextAnnotation_16wkbnd" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Contabilidade_Macro" isExecutable="true" camunda:historyTimeToLive="180">
    <bpmn:laneSet id="LaneSet_Contabil">
      <bpmn:lane id="Lane_Sistema" name="VIce-Presidente">
        <bpmn:flowNodeRef>Activity_T8</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_FimFiscal</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Assembleia" name="Assembleia Geral">
        <bpmn:flowNodeRef>Activity_T3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_T7</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ConsFiscal" name="Conselho Fiscal">
        <bpmn:flowNodeRef>Activity_T4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_T6</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ConsAdm" name="Conselho de Administração">
        <bpmn:flowNodeRef>Activity_T2</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Diretoria" name="Qualquer membro da diretoria">
        <bpmn:flowNodeRef>Activity_T5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_T1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_0rzypvl</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:userTask id="Activity_T3" name="Aprovar a proposta de programação anual">
      <bpmn:incoming>Flow_04idi0n</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_T2" name="Monitorar a elaboração e execução orçamentária">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_T4" name="Realizar a verificação periódica dos livros (a cada 6 meses)">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_T5" name="Elaborar o relatório anual e o balanço financeiro">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_T6" name="Emitir parecer escrito sobre os balanços e contas">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_T7" name="Discutir e homologar as contas aprovadas">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:scriptTask id="Activity_T8" name="Publicar relatório de atividades e demonstrações" scriptFormat="javascript">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:script>console.log("Relatório Fiscal Publicado");</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:endEvent id="Event_FimFiscal">
      <bpmn:incoming>Flow_9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Activity_T1" name="Elaborar a proposta de programação anual e orçamento">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_1gz1vp5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:startEvent id="StartEvent_1" name="Início do ano fiscal">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Activity_0rzypvl" name="Convocação da assembléia geral">
      <bpmn:incoming>Flow_1gz1vp5</bpmn:incoming>
      <bpmn:outgoing>Flow_04idi0n</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_04idi0n" sourceRef="Activity_0rzypvl" targetRef="Activity_T3" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Activity_T3" targetRef="Activity_T2" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Activity_T2" targetRef="Activity_T4" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Activity_T4" targetRef="Activity_T5" />
