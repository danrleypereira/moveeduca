    <bpmn:sequenceFlow id="Flow_8" sourceRef="Activity_T7" targetRef="Activity_T8" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Activity_T8" targetRef="Event_FimFiscal" />
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Activity_T1" />
    <bpmn:sequenceFlow id="Flow_1gz1vp5" sourceRef="Activity_T1" targetRef="Activity_0rzypvl" />
  </bpmn:process>
