<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_0x3r8u4" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.42.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.24.0">
  <bpmn:collaboration id="Collaboration_08jfb7m">
    <bpmn:participant id="Participant_185wyxq" name="Processo de contratação de serviços" processRef="Process_1o784co" />
    <bpmn:textAnnotation id="TextAnnotation_1xwzq2a">
      <bpmn:text>Os serviços devem estar alinhados aos objetivos sociais, como educação, saúde ou meio ambiente.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_04kk6lw">
      <bpmn:text>- Art. 24º, VIII (Íntegra): "Adquirir bens móveis e imóveis, ou de outra natureza, de valor até cinquenta salários mínimos; submeter a decisão à apreciação da Diretoria, quando o valor da aquisição for de até trezentos salários mínimos;".</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1g9ugch">
      <bpmn:text>Art. 22º, VII (Íntegra): "Autorizar despesas com valor acima de cinquenta salários mínimos;".</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_18l4j13">
      <bpmn:text>Art. 20º (Íntegra): "A organização adotará práticas de gestões administrativas, necessárias e suficientes, a coibir a obtenção de forma individual ou coletiva, de benefícios e vantagens pessoais, em decorrência da participação nos processos decisórios.".</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1t6d6g1">
      <bpmn:text>Art. 28º, VII (Íntegra): "assegurar que seus recursos financeiros tenham o rendimento condizente com perfil de risco adequado, que os recursos sejam gerenciados com eficiência, monitorando a gestão patrimonial dos ativos da associação e a elaboração e execução orçamentária realizada pelos gestores;".</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1c9fk1w">
      <bpmn:text>Art. 24º, VI (Íntegra): "VI. Autorizar a realização de despesas e efetuar os devidos pagamentos, bem como efetuar as transações financeiras e bancárias;"</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1p3gnq6" associationDirection="None" sourceRef="Gateway_1n8gcpr" targetRef="TextAnnotation_04kk6lw" />
    <bpmn:association id="Association_0pj3eqr" associationDirection="None" sourceRef="Activity_0whge3x" targetRef="TextAnnotation_18l4j13" />
    <bpmn:association id="Association_11y8gxz" associationDirection="None" sourceRef="Activity_0rygul8" targetRef="TextAnnotation_1t6d6g1" />
    <bpmn:association id="Association_0syj279" associationDirection="None" sourceRef="Gateway_1eqursv" targetRef="TextAnnotation_1g9ugch" />
    <bpmn:association id="Association_0mdvdve" associationDirection="None" sourceRef="Activity_0zzqmwt" targetRef="TextAnnotation_1c9fk1w" />
    <bpmn:association id="Association_1pyzp6o" associationDirection="None" sourceRef="Event_05hytpf" targetRef="TextAnnotation_1xwzq2a" />
  </bpmn:collaboration>
